#include <iostream>
using namespace std;

template <typename T>
class Stack {
    T arr[5];
    int top = -1;

public:
    void push(T value) {
        arr[++top] = value;
    }

    void display() {
        for(int i = 0; i <= top; i++)
            cout << arr[i] << " ";
    }
};

int main() {
    Stack<int> s;
    s.push(10);
    s.push(20);
    s.display();
}
