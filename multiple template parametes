#include <iostream>
using namespace std;

template <class T1, class T2>
class Pair {
public:
    T1 first;
    T2 second;

    Pair(T1 a, T2 b) {
        first = a;
        second = b;
    }

    void show() {
        cout << first << " " << second;
    }
};

int main() {
    Pair<int, string> p(1, "Template");
    p.show();
}
